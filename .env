# URL de conexión a PostgreSQL de Supabase
# Ejemplo: postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://user:password@host:port/dbname"
SECRET_KEY="supersecretkey-change-me-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"
